# App URL — http://localhost:3000 for dev, your Vercel URL for prod
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — get from supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://oljhhgodblludybhndgj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # SERVER-SIDE ONLY — never expose to browser

# AI — Groq
GROQ_API_KEY=placeholder_groq_key                       # get from console.groq.com/keys; SERVER-SIDE ONLY

# Founder guard — only this email can access /admin/* pages. Change before deploying.
FOUNDER_EMAIL=test@pura.local

# Twilio — SMS for patient check-in confirmation and daily token delivery
# Get these from console.twilio.com → Account Info (SID & Auth Token) and Phone Numbers
TWILIO_ACCOUNT_SID=placeholder_AC...         # Account SID, starts with AC; SERVER-SIDE ONLY
TWILIO_AUTH_TOKEN=placeholder_...            # Auth Token; SERVER-SIDE ONLY — never expose to browser
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx             # Twilio number that sends messages (must be SMS-capable)

# Supabase Auth webhook — set this after enabling the webhook in Supabase Dashboard → Auth → Hooks
# Generate with: openssl rand -hex 32
SUPABASE_AUTH_WEBHOOK_SECRET=placeholder_webhook_secret   # SERVER-SIDE ONLY

# Junction (wearable data) — junction.tryvital.io — formerly Vital
# Get these from your Junction dashboard → Settings → API Keys
JUNCTION_API_KEY=placeholder_...            # Secret API key; SERVER-SIDE ONLY — never expose to browser
JUNCTION_ENVIRONMENT=sandbox               # "sandbox" for dev/test, "production" for live data
JUNCTION_TEAM_ID=your_team_id_here         # Team ID shown in Junction dashboard Settings
JUNCTION_WEBHOOK_SECRET=placeholder_...    # Webhook signing secret for verifying inbound events
