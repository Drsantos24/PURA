{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/morning-send",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/purge-logs",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/weekly-insights",
      "schedule": "0 0 * * 1"
    }
  ]
}
