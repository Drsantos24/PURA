{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/morning-send",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/monitor-retry",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/monitor-digest",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/demo-reset",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/purge-logs",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/weekly-insights",
      "schedule": "0 0 * * 1"
    }
  ]
}
